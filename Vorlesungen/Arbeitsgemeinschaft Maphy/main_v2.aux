\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Detection of defects using Wilson loops. \textbf  {(a)} An electric defect is detected using a Wilson loop of star operators. \textbf  {(b)} A magnetic defect is detected using a Wilson loop of plaquette operators.}}{12}{figure.5}\protected@file@percent }
\newlabel{fig:wilsonloop}{{5}{12}{Detection of defects using Wilson loops. \textbf {(a)} An electric defect is detected using a Wilson loop of star operators. \textbf {(b)} A magnetic defect is detected using a Wilson loop of plaquette operators}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Double exchange of particles is topologically equivalent to one particle winding around the other. \textbf  {(a)} Double exchange process of two particles. \textbf  {(b)} Inner loop can be deformed in a continuous manner until it is infinitesimally small. \textbf  {(c)} When the inner loop has been deformed to be of 0 size, the outer particle simply winds around the inner particle.}}{13}{figure.6}\protected@file@percent }
\newlabel{fig:doubleswap}{{6}{13}{Double exchange of particles is topologically equivalent to one particle winding around the other. \textbf {(a)} Double exchange process of two particles. \textbf {(b)} Inner loop can be deformed in a continuous manner until it is infinitesimally small. \textbf {(c)} When the inner loop has been deformed to be of 0 size, the outer particle simply winds around the inner particle}{figure.6}{}}
