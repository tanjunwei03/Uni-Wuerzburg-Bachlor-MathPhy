\@writefile{toc}{\contentsline {section}{\numberline {II}Dynamics of Quantum Systems}{3}{section*.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Structure of local interactions. \textbf  {(a)} If the interaction is local, there is a number $N_\Phi $ such that $\Phi (X)$ is only nonzero for sets smaller than $N_\Phi $ (as pictured). \textbf  {(b)} Given an observable with support in the set $S_n$, application of the commutator allows for interactions within slightly wider sets, as shown in $S_{n+1}$.}}{5}{figure.2}\protected@file@percent }
\newlabel{fig:interactions}{{2}{5}{Structure of local interactions. \textbf {(a)} If the interaction is local, there is a number $N_\Phi $ such that $\Phi (X)$ is only nonzero for sets smaller than $N_\Phi $ (as pictured). \textbf {(b)} Given an observable with support in the set $S_n$, application of the commutator allows for interactions within slightly wider sets, as shown in $S_{n+1}$}{figure.2}{}}
