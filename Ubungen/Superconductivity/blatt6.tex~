Clarifying note on what we are doing: If we perform perturbation theory on the electron-phonon interaction, we will find terms like
\[\langle O\rangle = \int\left[\sum_{kk'qq'} g_q g_{q'}OA_q A_{q'}\overline{\psi}_{k+q,\sigma}\psi_{k,\sigma}\overline{\psi}_{k'+q',\sigma}\psi_{k',\sigma}\right]e^{-S_\text{el}[\psi,\overline{\psi}]-S_\text{ph}[z,\overline{z}]}\mathcal{D}(\psi,\overline{\psi}) \mathcal{D}(z,\overline{z})\]
If we want to compute 2 particle correlation functions, i.e. have two creation and two annihilation operators in $O$, we connect Green's functions into to the vertex elements to get the diagram above. Since the variables $A$ and those of $\psi$ are uncorrelated (corresponding to two different actions), we just find that
\[
\langle O\rangle = \int\left[\sum_{kk'qq'} g_q g_{q'}O\langle A_q A_{q'}\rangle\overline{\psi}_{k+q,\sigma}\psi_{k,\sigma}\overline{\psi}_{k'+q',\sigma}\psi_{k',\sigma}\right]e^{-S_\text{el}[\psi,\overline{\psi}]}\mathcal{D}(\psi,\overline{\psi})
\]
By an electron-electron interaction, we mean an interaction vertex that reproduces the correlation functions. If we had a two-particle interaction $S_\text{int} = \sum_{0123}V_{0123}\overline{\psi}_3\psi_1\overline{\psi}_2\psi_0$, the expectation values would be given by
\[\langle O\rangle = \int \left[\sum_{0123} OV_{0123}\overline{\psi}_3\psi_1\overline{\psi}_2\psi_0\right] e^{-S_\text{el}[\psi,\overline{\psi}]}\mathcal{D}(\psi,\overline{\psi})\]
where 0123 are just shorthand for phase space coordinates. Thus, by comparison, setting $k'=-k$ and noting that $q'=-q$ for the functional average to be nonvanishing, we find that the effective interaction is given by
\[
V_{k,k'} = |g_{k'-k}|^2 \, D_0(k' - k, \omega).
\]
where the propagator $D_0$ is the functional average $\langle A_q A_{q'}\rangle$ (note implicit time ordering in path integral).

If we take the jellium model acoustic phonons $g_q =g\sqrt{q},~\omega_q = uq$ we find that
\begin{align*}
	V_{k,k'} &= |g_{k'-k}|^2D_0(k'-k,\omega) \\
	&= g^2 |q| \frac{2\omega_q}{\omega^2 - \omega_q^2 + i\eta}\\
	&= g^2 |q| \frac{2u |q|}{\omega^2 - u^2 q^2 + i\eta}\\
	&= g^2 |q| \frac{2u |q|}{-u^2 q^2 + i\eta}\\
	&= -\frac{2g^2}{u}.\qedhere
\end{align*}
	\end{parts}
\end{proof}
\begin{Problem}[Cooper pairs with finite momentum]

Generalize Cooper’s calculation to a pair with finite momentum.
In particular:

\begin{itemize}
\item[(a)] Show that the operator that creates a Cooper pair at a finite
momentum \(\vec{p}\),
\[
\Lambda_{\vec{p}}^\dagger
=
\int d^3x\, d^3x'\,
\phi(\vec{x}-\vec{x}')
\psi_\uparrow^\dagger(\vec{x})
\psi_\downarrow^\dagger(\vec{x}')
e^{i\vec{p}\cdot(\vec{x}+\vec{x}')/2},
\tag{9}
\]
can be rewritten in the form
\[
\Lambda^\dagger(\vec{p})
=
\sum_{\vec{k}}
\phi(\vec{k})\,
c_{\vec{k}+\vec{p}/2,\uparrow}^\dagger
c_{-\vec{k}+\vec{p}/2,\downarrow}^\dagger .
\tag{10}
\]

\item[(b)] Show that the energy \(E_p\) of the pair state
\(\Lambda^\dagger(\vec{p})|\mathrm{FS}\rangle\) is given by the (complex)
roots \(z = E_p\) of the equation
\[
1 + \frac{g_0}{V}
\sum_{0 < \epsilon_k < \omega_D}
\frac{1}{z - (\epsilon_{k+p/2} + \epsilon_{k-p/2})}
= 0 .
\tag{11}
\]

Here
\[
|\mathrm{FS}\rangle
=
\prod_{k<k_F}
c_{k\uparrow}^\dagger
c_{k\downarrow}^\dagger
|0\rangle
\]
defines the filled Fermi sea,
\(\epsilon_k\) is the energy of an electron with momentum \(k\),
\(g_0\) is the strength of the phonon-mediated electron--electron interaction,
\(V\) is a volume factor, and \(\omega_D\) is the Debye frequency.
\end{itemize}

\end{Problem}
\begin{proof}
	\begin{parts}
	\item We begin by performing a fourier transform
		\[
			\psi^\dagger(\va r)=\frac{1}{\sqrt{V} }\sum_{\va k}e^{-i\va k \va r}c_{\va k}^\dagger\qquad \psi(\va r) = \frac{1}{\sqrt{V} }\sum_{\va k} e^{i\va k \va r}c_{\va k}
		.\] 
		Substituting, we find that
		\begin{align*}
			\Psi_{\va p}^\dagger &= \int \dd[3]{x}\dd[3]{x'} \phi(\va x - \va x')\psi_{\uparrow}^\dagger(\va x) \psi_{\downarrow}^\dagger(\va x') e^{i\va p(\va x + \va x') / 2} \\
					     &= \frac{1}{V}\sum_{\va k, \va k'}\int \dd[3]{x}\dd[3]{x'}\phi(\va x - \va x') e^{-i\va k \va x}e^{-i\va k'\va x'}c^\dagger_{\va k, \uparrow} c^\dagger_{\va k', \downarrow} e^{i\va p (\va x + \va x') / 2}\\
					     &= \frac{1}{V}\sum_{\va k, \va k'}\int \dd[3]{x}\dd[3]{x'}\phi(\va x - \va x') c^\dagger_{\va k, \uparrow} c^\dagger_{\va k', \downarrow} e^{i(-\va k + \va p / 2)\va x}e^{i(-\va k' + \va p / 2)\va x'}\\
					     &= \frac{1}{V}\sum_{\va k, \va k'}\int \dd[3]{R}\dd[3]{x'}\phi(\va R) c^\dagger_{\va k, \uparrow} c^\dagger_{\va k', \downarrow} e^{i(-\va k + \va p / 2)(\va x'+\va R)}e^{i(-\va k' + \va p / 2)\va x'}\\
					     &= \frac{1}{V}\sum_{\va k, \va k'}\int \dd[3]{x'}\phi(\va k - \va p / 2) c^\dagger_{\va k, \uparrow} c^\dagger_{\va k', \downarrow} e^{i(-\va k + \va p / 2)\va x'}e^{i(-\va k' + \va p / 2)\va x'}\\
					     &= \sum_{\va k, \va k'}\phi(\va k - \va p / 2) c^\dagger_{\va k, \uparrow} c^\dagger_{\va k', \downarrow}\delta_{\va p - \va k - \va k'}\\ 
					     &= \sum_{\va k}\phi(\va k - \va p / 2) c^\dagger_{\va k, \uparrow} c^\dagger_{-\va k + \va p, \downarrow}\\
					     &= \sum_{\va k}\phi(\va k ) c^\dagger_{\va k + \va p / 2, \uparrow} c^\dagger_{-\va k + \va p / 2, \downarrow}
		\end{align*}
	\item We write the eigenvalue equation $H\ket{\psi} = E\ket{\psi}$ to get
			\[
			E_{\vec{p}}\sum_{\vec k}\phi_{\vec{k}} \ket{\vec{k}, \vec{p}} = \sum_{|\vec{k} + \vec{p}/2|\ge k_F} (\epsilon_{\vec{k}+\vec{p}/2}+\epsilon_{\vec{k}-\vec{p}/2})\phi_{\vec{k}}\ket{\vec{k},\vec{p}}+\sum_{\vec{k},\vec{k}'}\ket{\vec{k},\vec{p}}\mel{\vec{k},\vec{p}}{V}{\vec{k}',\vec{p}}\phi_{\vec{k}',\vec{p}}
		\]
		where we have defined
		\[
		\ket{\vec{k},\vec{p}} = c^\dagger_{\vec{k}+\vec{p}/2,\uparrow} c^\dagger_{-\vec{k}+\vec{p}/2,\downarrow}\ket{FS}
		.\] 
		Here, we note that since $V$ does not change the total momentum, even though $\dyad{\vec{k},\vec{p}}{\vec{k},\vec{p}}$ is not a full resolution of the identity (which would involve a sum over $\vec{p}$), it still does not change the expression. Comparing coefficients of $\ket{\vec{k},\vec{p}}$ and considering the special case where the matrix element is a constant $\mel{\vec{k},\vec{p}}{V}{\vec{k},\vec{p}}=-g_0 / V$ just like in the BCS model, we find the equation
		\[
		E_{\vec{p}}\phi_{\vec{k}}=(\epsilon_{\vec{k}+\vec{p} / 2}-\epsilon_{\vec{k} - \vec{p} / 2})\phi_{\vec k} - \frac{g_0}{V}\sum_{0< \epsilon_{\vec{k} \pm \vec{p} / 2} <\omega_D} \phi_{\vec{k}'}
		\] 
		where the interaction is once again limited to pairs with energy less than the Debye frequency. We can solve this to find
		\[
		\phi_{\vec{k}} = \frac{1}{\epsilon_{\vec{k} + \vec{p} / 2} + \epsilon_{\vec{k} - \vec{p} / 2} - E_{\vec{p}}} \frac{g_0}{V}\sum_{0<\epsilon_{\vec{k}\pm \vec{p} / 2} < \omega_D} \phi_{\vec{k}'}
		.\] 
		Finally, we sum over $\vec{k}$ and cancel out the common sum of $\phi_{\vec{k}'}$ to find
		\[
		1 + \frac{g_0}{V}\sum_{0<\epsilon_{\vec{k} \pm \vec{p} / 2}<\omega_D}\frac{1}{E_{\vec{p}} - \epsilon_{\vec{k} + \vec{p} / 2} - \epsilon_{\vec{k} - \vec{p} / 2}}=0
		.\] 
		This is the desired equation that $E_{\vec{p}}$ must solve.\qedhere
	\end{parts}
\end{proof}
