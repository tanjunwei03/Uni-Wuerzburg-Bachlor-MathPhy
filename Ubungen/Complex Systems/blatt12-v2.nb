Cell[BoxData[
 RowBox[{
  RowBox[{"\[Sigma]", "[", 
   RowBox[{"k_", ",", "x_", ",", "n_"}], "]"}], ":=", " ", 
  RowBox[{"KroneckerProduct", "[", 
   RowBox[{
    RowBox[{"IdentityMatrix", "[", 
     RowBox[{"2", "^", 
      RowBox[{"(", 
       RowBox[{"k", "-", "1"}], ")"}]}], "]"}], ",", 
    RowBox[{"PauliMatrix", "[", "x", "]"}], ",", " ", 
    RowBox[{"IdentityMatrix", "[", 
     RowBox[{"2", "^", 
      RowBox[{"(", 
       RowBox[{"n", "-", "k"}], ")"}]}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.991905321894842*^9, 3.991905349612219*^9}, {
  3.9919057746026325`*^9, 3.991905776073412*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"c989d8b2-650a-f94f-bfc4-cb3f20cc080d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"IsingHamiltonian", "[", "n_", "]"}], ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"\[Sigma]", "[", 
       RowBox[{"k", ",", "1", ",", "n"}], "]"}], ".", 
      RowBox[{"\[Sigma]", "[", 
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"k", "+", "1"}], ",", "n", ",", "1"}], "]"}], ",", "1", ",",
         "n"}], "]"}]}], "+", 
     RowBox[{"\[Lambda]", " ", 
      RowBox[{"\[Sigma]", "[", 
       RowBox[{"k", ",", "3", ",", "n"}], "]"}]}]}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.99190539639839*^9, 3.991905477082365*^9}, 
   3.9919055233481884`*^9, {3.991905686332567*^9, 3.991905698909378*^9}, {
   3.991905779317749*^9, 3.991905791846586*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"676f1609-fb1d-e642-ada3-5ec68406b358"],

Cell[BoxData[
 RowBox[{
  RowBox[{"spectralgap", "[", "lst_", "]"}], ":=", " ", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "-", 
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "&"}], ")"}], "[", 
   RowBox[{"TakeSmallest", "[", 
    RowBox[{"lst", ",", "2"}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.991905930908825*^9, 3.99190599034853*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"cc52e534-f443-a842-a579-f939f849baf5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Lambda]12", " ", "=", " ", 
   RowBox[{"spectralgap", "/@", 
    RowBox[{"Monitor", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Eigenvalues", "[", 
         RowBox[{
          RowBox[{"IsingHamiltonian", "[", "n", "]"}], "/.", 
          RowBox[{"\[Lambda]", "->", "1.2"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "2", ",", "12", ",", "2"}], "}"}]}], "]"}], ",", 
